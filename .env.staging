# SAFE PREFILLED STAGING ENV FOR FIRST FACTORY BRING-UP
# Secrets intentionally redacted. Copy them locally from your existing .env or secret store.
# This version is optimized for: mobkit runtime + real Goldfish + shadow/preflight first + Binance first venue.
# Do not commit with secrets.

########################################
# 1) TARGET FACTORY RUNTIME
########################################
AGENTIC_FACTORY_MODE=full
FACTORY_REAL_AGENTS_ENABLED=true
FACTORY_RUNTIME_BACKEND=mobkit
FACTORY_ENABLE_GOLDFISH_PROVENANCE=true
FACTORY_GOLDFISH_STRICT_MODE=false
FACTORY_MOBKIT_CONFIG_PATH=./config/mob.target-state.toml
FACTORY_MOBKIT_GATEWAY_BIN=/tmp/meerkat-mobkit/target/release/rpc_gateway

########################################
# 2) PROVIDER ORDER + LLM KEYS
########################################
FACTORY_AGENT_PROVIDER_ORDER=codex,openai_api,deterministic
OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>
ANTHROPIC_API_KEY=<YOUR_ANTHROPIC_API_KEY>
GOOGLE_API_KEY=<YOUR_GOOGLE_API_KEY>
FACTORY_AGENT_OLLAMA_FALLBACK_ENABLED=false
FACTORY_AGENT_OLLAMA_MODEL=qwen2.5:32b

########################################
# 3) LEGACY / FALLBACK MODEL DEFAULTS
# Keep these for fallback until Sonnet finishes the target-state routing.
########################################
FACTORY_AGENT_CODEX_MODEL_CHEAP=gpt-5.1-codex-mini
FACTORY_AGENT_CODEX_MODEL_STANDARD=gpt-5.1-codex
FACTORY_AGENT_CODEX_MODEL_HARD=gpt-5.2-codex
FACTORY_AGENT_CODEX_MODEL_FRONTIER=gpt-5.3-codex
FACTORY_AGENT_CODEX_MODEL_DEEP=gpt-5.4
FACTORY_AGENT_CODEX_MODEL_SPARK=gpt-5.3-codex-spark
FACTORY_AGENT_REASONING_CHEAP=medium
FACTORY_AGENT_REASONING_STANDARD=medium
FACTORY_AGENT_REASONING_HARD=high
FACTORY_AGENT_REASONING_FRONTIER=high
FACTORY_AGENT_REASONING_DEEP=high
FACTORY_AGENT_LOG_DIR=data/factory/agent_runs
FACTORY_AGENT_POST_EVAL_CRITIQUE_ENABLED=false
FACTORY_AGENT_DEMO_FAMILY=binance_funding_contrarian

########################################
# 4) OPERATING MODE FOR FIRST BRING-UP
# Shadow / preflight first. No live trading.
########################################
FACTORY_ENABLE_WEB_IDEA_RESEARCH=false
FACTORY_IDEA_SOURCE_FILE=./IDEAS.md
FACTORY_ENABLE_PAPER_TRADING=false
FACTORY_ENABLE_LIVE_TRADING=false
FACTORY_EXECUTION_AUTOSTART_ENABLED=false
PAPER_TRADING=false
FUNDING_MODE=paper

########################################
# 5) FIRST-RUN SCOPE GUARDS
########################################
FACTORY_MAX_ACTIVE_FAMILIES=1
FACTORY_MAX_ACTIVE_MODELS_PER_FAMILY=1
FACTORY_MAX_CHALLENGERS_PER_FAMILY=1
FACTORY_ALLOW_AUTONOMOUS_MUTATION=false
FACTORY_ALLOW_AUTONOMOUS_PAPER_PROMOTION=false
FACTORY_RUNTIME_MAX_ACTIVE_PAPER_LANES=1
FACTORY_RUNTIME_MAX_ACTIVE_PAPER_LANES_PER_FAMILY=1

########################################
# 6) EVALUATION / PROMOTION GATES
########################################
FACTORY_BACKTEST_PASS_MONTHLY_ROI=0.05
FACTORY_REQUIRE_FORWARDTEST_PASS=true
FACTORY_REQUIRE_PAPER_EVIDENCE_FOR_CHALLENGER=true
FACTORY_PAPER_GATE_MONTHLY_ROI_PCT=5.0
FACTORY_PAPER_GATE_MAX_DRAWDOWN_PCT=8.0
FACTORY_PAPER_GATE_MIN_DAYS=30
FACTORY_PAPER_GATE_MIN_FAST_TRADES=50
FACTORY_PAPER_GATE_MIN_SLOW_SETTLED=10

########################################
# 7) COST / BUDGET GOVERNANCE
########################################
FACTORY_DAILY_INFERENCE_BUDGET_USD=15
FACTORY_WEEKLY_INFERENCE_BUDGET_USD=75
FACTORY_STRICT_BUDGETS=false
FACTORY_BUDGET_REVIEWER_REMOVAL_RATIO=0.70
FACTORY_BUDGET_FORCE_CHEAP_RATIO=0.80
FACTORY_BUDGET_SINGLE_AGENT_RATIO=0.90

########################################
# 8) GOLDFISH
########################################
FACTORY_GOLDFISH_ROOT=research/goldfish
GOLDFISH_PROJECT_NAME=agentictrading
GOLDFISH_WORKSPACE_ROOT=./.goldfish
GOLDFISH_ARTEFACT_ROOT=./artifacts/goldfish

########################################
# 9) OBSERVABILITY / OUTPUTS
########################################
FACTORY_LOG_LEVEL=INFO
FACTORY_LOG_JSON=true
FACTORY_OPERATOR_STATUS_PATH=./artifacts/operator_status.json
FACTORY_PROMOTION_REPORT_PATH=./artifacts/trade_ready_models.md
RESEARCH_FACTORY_PORTFOLIO_ID=research_factory
PREDICTION_POLICY_GATE_PATH=data/prediction_policy_gate.json
FACTORY_ROOT=data/factory
EXECUTION_PORTFOLIO_STATE_ROOT=data/portfolios
PORTFOLIO_STATE_ROOT=data/portfolios
PAPER_STATE_PATH=data/state/paper_executor_state.json
PAPER_TRADES_LOG_PATH=data/state/paper_trades.jsonl

########################################
# 10) DATA + EXECUTION TARGET FOR FIRST STAGED RUN
# You trade multiple venues, but first bring-up should use ONE venue.
# Recommended first venue: Binance futures paper/testnet, because your demo family is Binance funding contrarian.
########################################
FACTORY_PRIMARY_MARKET_DATA_PROVIDER=binance
FACTORY_SECONDARY_MARKET_DATA_PROVIDER=yahoo
FACTORY_PAPER_BROKER_PROVIDER=binance_futures_testnet
FACTORY_PAPER_BROKER_API_KEY=<YOUR_BINANCE_FUTURES_TESTNET_API_KEY>
FACTORY_PAPER_BROKER_API_SECRET=<YOUR_BINANCE_FUTURES_TESTNET_API_SECRET>
FACTORY_PAPER_BROKER_BASE_URL=https://demo-fapi.binance.com

########################################
# 11) VENUE UNIVERSE CONTEXT
# Keep for later multi-venue expansion after first successful shadow cycle.
########################################
FACTORY_ACTIVE_EXECUTION_VENUES=betfair,polymarket,binance,alpaca
FACTORY_BACKTEST_DATA_SOURCES=betfair,polymarket,binance,yahoo
PREDICTION_MODEL_KINDS=hybrid_logit,market_calibrated

########################################
# 12) BINANCE
########################################
BINANCE_SPOT_PROD_URL=https://api.binance.com
BINANCE_FUTURES_PROD_URL=https://fapi.binance.com
BINANCE_SPOT_TESTNET_URL=https://testnet.binance.vision
BINANCE_FUTURES_TESTNET_URL=https://demo-fapi.binance.com
BINANCE_FUTURES_API_KEY=<YOUR_BINANCE_FUTURES_API_KEY>
BINANCE_FUTURES_API_SECRET=<YOUR_BINANCE_FUTURES_API_SECRET>
BINANCE_SPOT_API_KEY=<YOUR_BINANCE_SPOT_API_KEY>
BINANCE_SPOT_API_SECRET=<YOUR_BINANCE_SPOT_API_SECRET>
BINANCE_FUTURES_TESTNET_API_KEY=<YOUR_BINANCE_FUTURES_TESTNET_API_KEY>
BINANCE_FUTURES_TESTNET_API_SECRET=<YOUR_BINANCE_FUTURES_TESTNET_API_SECRET>
BINANCE_SPOT_TESTNET_API_KEY=<YOUR_BINANCE_SPOT_TESTNET_API_KEY>
BINANCE_SPOT_TESTNET_API_SECRET=<YOUR_BINANCE_SPOT_TESTNET_API_SECRET>

########################################
# 13) ALPACA
# Not used for first staged execution in this file, but kept because your stack already has it.
########################################
ALPACA_PAPER_API_KEY=<YOUR_ALPACA_PAPER_API_KEY>
ALPACA_PAPER_API_SECRET=<YOUR_ALPACA_PAPER_API_SECRET>
ALPACA_PAPER_TRADING_URL=https://paper-api.alpaca.markets
ALPACA_LIVE_TRADING_URL=https://api.alpaca.markets
ALPACA_MARKET_DATA_URL=https://data.alpaca.markets

########################################
# 14) BETFAIR
########################################
BF_USERNAME=benjamin.pommeraud@gmail.com
BF_PASSWORD=<YOUR_BETFAIR_PASSWORD>
BF_APP_KEY=<YOUR_BETFAIR_APP_KEY>
BF_CERTS_PATH=./certs
BF_LOCALE=spain

########################################
# 15) POLYMARKET
########################################
POLYMARKET_ENABLED=true
POLYMARKET_SPORTS_ONLY=true
POLYMARKET_ROLE=confirmation
POLYMARKET_HTTP_BASE_URL=https://gamma-api.polymarket.com
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws
POLYMARKET_MAX_EVENTS=250
POLYMARKET_QF_ENABLED=true
POLYMARKET_QF_CLOB_HTTP_BASE_URL=https://clob.polymarket.com
POLYMARKET_QF_CLOB_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws
POLYMARKET_QF_HTTP_TIMEOUT_SECONDS=10.0

########################################
# 16) SUPPORTING INFRA
########################################
REDIS_URL=redis://localhost:6379
DATABASE_URL=
EXECUTION_REPO_ROOT=.
INITIAL_BALANCE_EUR=1000.00
STAKE_FRACTION=0.10

########################################
# 17) TELEGRAM / ALERTING
########################################
TELEGRAM_BOT_TOKEN=<MISSING_IF_YOU_WANT_TELEGRAM_ALERTS>
TELEGRAM_CHAT_ID=<MISSING_IF_YOU_WANT_TELEGRAM_ALERTS>

########################################
# 18) LEGACY FEATURE FLAGS KEPT FROM CURRENT ENV
########################################
CASCADE_ALPHA_ENABLED=true
CONTRARIAN_LEGACY_ENABLED=true
POLYMARKET_QF_ENABLED=true
