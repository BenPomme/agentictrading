# Emergency rollback config — factory-refactor-v1
#
# Apply these two overrides (via environment or config.py patch) to restore
# the pre-cutover behaviour without any code changes.
#
# Step 1: force legacy runtime backend
FACTORY_RUNTIME_BACKEND=legacy

# Step 2: disable Goldfish provenance (uses NullGoldfishClient, local JSONL only)
FACTORY_ENABLE_GOLDFISH_PROVENANCE=false

# Optional: disable mobkit entirely so RuntimeManager never attempts MobkitRuntime init
# FACTORY_ENABLE_MOBKIT=false

# To re-enable new stack after rollback, remove or revert to:
# FACTORY_RUNTIME_BACKEND=mobkit
# FACTORY_ENABLE_GOLDFISH_PROVENANCE=true
